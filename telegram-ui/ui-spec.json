      "id": "alerts",
      "title": "Alerts",
      "items": [
        { "id": "create", "label": "Create", "callback": "pmx:menu:alerts:create" },
        { "id": "my", "label": "My Alerts", "callback": "pmx:menu:alerts:my" },
        { "id": "back", "label": "Back", "callback": "pmx:nav:back:agents" }
      ]
    },
    "settings": {
      "id": "settings",
      "title": "Settings",
      "items": [
        { "id": "wallet", "label": "Wallet", "callback": "pmx:menu:settings:wallet" },
