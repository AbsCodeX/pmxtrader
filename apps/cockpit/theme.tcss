/* pmxtrader cockpit — GoAccess-dark dashboard + light panels */

Screen {
    layout: vertical;
    background: #010409;
    color: #c9d1d9;
}

Header {
    background: #161b22;
    color: #c9d1d9;
    border-bottom: solid #30363d;
    dock: top;
    height: 1;
}

Footer {
    background: #161b22;
    color: #8b949e;
    border-top: solid #30363d;
    dock: bottom;
    height: 1;
}

#main-row {
    height: 1fr;
}

ContentSwitcher {
    width: 1fr;
    height: 1fr;
}

ContentSwitcher > * {
    height: 1fr;
}

Button {
    margin-right: 1;
}

Input {
    background: #ffffff;
    border: solid #c5d0de;
    margin-right: 1;
}

Input:focus {
    border: solid #2563eb;
}

Select {
    background: #ffffff;
    border: solid #c5d0de;
    width: 16;
    margin-right: 1;
}

DataTable {
    background: #0d1117;
    border: solid #30363d;
    color: #c9d1d9;
}

NavSidebar {
    background: #0d1117;
    border-right: solid #30363d;
}

RichLog, OutputLog {
    scrollbar-background: #eef2f7;
    scrollbar-color: #2563eb;
}

ActivityLog {
    dock: bottom;
    height: 5;
    max-height: 5;
}

TickerBar {
    dock: top;
    height: 1;
}

ConfirmCommandModal {
    align: center middle;
}

#confirm-box {
    width: 78;
    height: auto;
    border: thick #c62828;
    background: #ffffff;
    padding: 1 2;
}

CommandPalette {
    align: center top;
    padding-top: 2;
}
