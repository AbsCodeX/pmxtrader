/* pmxtrader cockpit — terminal trading desk (Bloomberg/htop/lazygit inspired) */

Screen {
    layout: vertical;
    background: #050608;
    color: #e2eaf2;
}

Static, Label, Input, RichLog, OutputLog, DataTable {
    color: #e2eaf2;
}

Header {
    background: #0a0e14;
    color: #00ff9c;
    border-bottom: solid #1a3a2a;
    dock: top;
    height: 1;
}

Footer {
    background: #0a0e14;
    color: #5a6a7a;
    border-top: solid #1a2332;
    dock: bottom;
    height: 1;
}

#main-row {
    height: 1fr;
}

ContentSwitcher {
    width: 1fr;
    height: 1fr;
}

ContentSwitcher > * {
    height: 1fr;
}

Button {
    margin-right: 0;
    background: #0a0e14;
    color: #00d4ff;
    border: solid #1a2332;
    min-width: 0;
    height: 1;
    padding: 0 1;
}

Button:hover {
    background: #101820;
    border: solid #00d4ff;
}

Button.-primary {
    background: #0d1a12;
    color: #00ff9c;
    border: solid #1a4a2a;
}

Button.-success {
    background: #0d1a12;
    color: #00ff9c;
    border: solid #00ff9c;
}

Input {
    background: #0a0e14;
    color: #eef2f8;
    border: solid #1a3a4a;
    margin-right: 1;
}

Input:focus {
    border: solid #00d4ff;
}

Select {
    background: #0a0e14;
    color: #e0e8f0;
    border: solid #1a3a4a;
    width: 16;
    margin-right: 1;
}

DataTable {
    background: #050608;
    border: solid #1a2332;
    color: #e2eaf2;
}

DataTable > .datatable--header {
    background: #0a0e14;
    color: #00d4ff;
    text-style: bold;
}

DataTable > .datatable--cursor {
    background: #0d1a12;
    color: #00ff9c;
}

NavSidebar {
    background: #050608;
    border-right: solid #1a2332;
}

RichLog, OutputLog {
    scrollbar-background: #0a0e14;
    scrollbar-color: #00d4ff;
}

ActivityLog {
    dock: bottom;
    height: 4;
    max-height: 4;
}

TickerBar {
    dock: top;
    height: 1;
}

ConfirmCommandModal {
    align: center middle;
}

#confirm-box {
    width: 78;
    height: auto;
    border: thick #ff4466;
    background: #0a0e14;
    color: #e0e8f0;
    padding: 1 2;
}

CommandPalette {
    align: center top;
}
