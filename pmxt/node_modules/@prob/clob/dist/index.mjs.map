{
  "name": "@prob/clob",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "test": "vitest",
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@prob/core": "workspace:*",
    "@prob/types": "workspace:*",
    "bignumber.js": "^9.3.1",
    "ky": "^1.14.0",
    "viem": "^2.38.3",
    "isows": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  }
}