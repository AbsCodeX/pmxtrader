{
  "name": "polymarket-us",
  "version": "0.1.1",
  "description": "Polymarket US TypeScript SDK",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "keywords": [
    "polymarket",
    "prediction-markets",
    "trading",
    "api",
    "sdk"
  ],
  "author": "Polymarket Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Polymarket/polymarket-us-typescript"
  },
  "homepage": "https://docs.polymarket.us",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@noble/ed25519": "^2.2.3",
    "ws": "^8.18.0"
  },
  "files": [
    "dist"
  ],
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.14",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  }
}