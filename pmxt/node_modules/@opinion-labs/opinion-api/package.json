{
  "name": "@opinion-labs/opinion-api",
  "version": "0.3.0",
  "description": "Auto-generated OpenAPI client for Opinion Prediction Market API",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "generate": "openapi-ts",
    "build": "tsc && node scripts/fix-esm-imports.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run generate && npm run build"
  },
  "keywords": [
    "opinion",
    "prediction-market",
    "api-client",
    "openapi"
  ],
  "author": "Opinion Labs",
  "license": "MIT",
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.85.2",
    "typescript": "^5.3.0"
  }
}
