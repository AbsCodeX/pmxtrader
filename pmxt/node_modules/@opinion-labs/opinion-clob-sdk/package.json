{
  "name": "@opinion-labs/opinion-clob-sdk",
  "version": "0.6.0",
  "description": "TypeScript SDK for Opinion Labs Prediction Market CLOB operations",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run --exclude \"tests/test_{integration,websocket}.ts\"",
    "test:watch": "vitest --exclude \"tests/test_{integration,websocket}.ts\"",
    "test:unit": "vitest run --exclude \"tests/test_{integration,websocket}.ts\"",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "opinion",
    "prediction-market",
    "clob",
    "sdk",
    "viem",
    "ethereum",
    "bnb-chain"
  ],
  "author": "Opinion Labs",
  "license": "MIT",
  "dependencies": {
    "@opinion-labs/opinion-api": "^0.3.0",
    "https-proxy-agent": "^7.0.6",
    "undici": "^6.0.0",
    "viem": "^2.21.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "dotenv": "^16.3.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4"
  }
}
